TOKEN=your-telegram-bot-token-here
USERNAME=your-bot-username-here
# On one VPS with several bots: unique Docker Compose project name per folder (stack name).
# Example for this repo: tg_pooling_hard — other bots use e.g. tg_simple_bot, tg_other_bot.
COMPOSE_PROJECT_NAME=telegram-bot-pooling-hard

# PostgreSQL (non-secret bits). Password must NOT live in this file for Compose:
# create a one-line file secrets/postgres_password (see README). Same path on VPS; CI writes it from GitHub secret VPS_POSTGRES_PASSWORD.
POSTGRES_DB=telegram_bot_pooling_hard
POSTGRES_USER=postgres

# Optional: override DB connection when using Docker secrets (defaults match postgres service)
# DB_HOST=postgres
# DB_PORT=5432

# Optional: full DSN instead of DB_PASSWORD_FILE mode (local only; avoid committing real passwords)
# DB_DSN=

# Optional: Redis for caching (e.g. specialty list pages). Compose defaults to redis:6379 when unset.
# REDIS_ADDR=
# Telegram update transport guards (0 or empty disables each limiter).
# TELEGRAM_RATE_LIMIT_MSG_PER_MIN=0
# TELEGRAM_RATE_LIMIT_CALLBACK_PER_MIN=0

# Optional app runtime settings
APP_ENV=dev
LOG_LEVEL=debug
LOG_FORMAT=text

# Optional refund policy tuning for clinic booking cancellations:
# - partial window: Go duration format (e.g. 24h, 90m)
# - partial percent: integer in range 0..100
# CLINIC_REFUND_PARTIAL_WINDOW=24h
# CLINIC_REFUND_PARTIAL_PERCENT=50

# Optional health/readiness endpoints (disabled when empty)
# HTTP_HEALTH_ADDR=:8080

# Outbox worker (enabled by default). Set OUTBOX_WORKER_ENABLED=false to disable polling.
# OUTBOX_WORKER_ENABLED=true

# Optional: POST JSON dead-letter notifications when an outbox event exhausts retries (see docs/outbox-dead-letter.md)
# OUTBOX_DEAD_LETTER_WEBHOOK=https://hooks.example.com/outbox-dead
