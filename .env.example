TOKEN=your-telegram-bot-token-here
USERNAME=your-bot-username-here
# Optional: set unique compose project name per bot on one server
COMPOSE_PROJECT_NAME=telegram-bot-pooling-middle

# PostgreSQL (Docker Compose). Add to your local .env (never commit .env):
#   POSTGRES_PASSWORD=<strong-random-secret>
POSTGRES_DB=telegram_bot_pooling_middle
POSTGRES_USER=postgres

# Connection string for the bot. Must match POSTGRES_* above, e.g.:
# DB_DSN=postgres://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB?sslmode=disable
DB_DSN=

# Optional app runtime settings
APP_ENV=dev
LOG_LEVEL=debug
LOG_FORMAT=text
