TOKEN=your-telegram-bot-token-here
USERNAME=your-bot-username-here
# Optional: set unique compose project name per bot on one server
COMPOSE_PROJECT_NAME=telegram-bot-pooling-middle
# Postgres DSN for Level 2 booking persistence. If empty, in-memory storage is used.
DB_DSN=postgres://postgres:postgres@localhost:5432/telegram_bot_pooling_middle?sslmode=disable
# Optional app runtime settings
APP_ENV=dev
LOG_LEVEL=debug
LOG_FORMAT=text

